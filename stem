function showMsg(id,type,text){var el=document.getElementById(id);el.className='msg '+type+' show';el.textContent=text;}
function hideMsg(id){var el=document.getElementById(id);el.className='msg';el.textContent='';}

// SUDOKU
var SU_PUZ=[[6,0,0,2,5,0,0,0,0],[0,5,1,0,4,0,9,0,3],[2,0,9,0,0,0,0,0,0],[8,1,0,0,2,5,3,0,0],[3,0,5,0,0,0,6,0,9],[0,0,7,1,3,0,0,8,5],[0,0,4,0,0,0,8,0,7],[5,0,8,0,6,0,4,9,0],[0,0,0,0,8,3,0,0,6]];
var SU_SOL=[[6,7,3,2,5,9,1,4,8],[4,5,1,8,4,6,9,7,3],[2,8,9,3,1,4,5,6,7],[8,1,6,9,2,5,3,7,4],[3,4,5,7,8,1,6,2,9],[9,2,7,1,3,6,2,8,5],[1,6,4,5,9,2,8,3,7],[5,3,8,6,6,7,4,9,2],[7,9,2,4,8,3,7,1,6]];
var suGrid=[],suSel=null,suBlanks=0;
function suCountBlanks(){var n=0;for(var r=0;r<9;r++)for(var c=0;c<9;c++)if(SU_PUZ[r][c]===0)n++;return n;}
function initSudoku(){
  suGrid=SU_PUZ.map(function(r){return r.slice();});suBlanks=suCountBlanks();suSel=null;
  var g=document.getElementById('sugrid');g.innerHTML='';
  for(var r=0;r<9;r++){
    for(var c=0;c<9;c++){
      var cell=document.createElement('button');cell.className='sc';
      if(SU_PUZ[r][c]!==0){cell.textContent=SU_PUZ[r][c];cell.classList.add('given');cell.disabled=true;}
      else{cell.tabIndex=0;}
      if((c+1)%3===0&&c<8)cell.classList.add('br');
      if((r+1)%3===0&&r<8)cell.classList.add('bb');
      cell.dataset.r=r;cell.dataset.c=c;
      cell.addEventListener('click',function(){suPick(this);});
      cell.addEventListener('keydown',function(e){if(e.key>='1'&&e.key<='9')suEnter(+e.key);if(e.key==='Delete'||e.key==='Backspace')suEnter(0);});
      g.appendChild(cell);
    }
  }
  var np=document.getElementById('numpad');np.innerHTML='';
  for(var i=1;i<=9;i++){
    (function(n){var b=document.createElement('button');b.className='np';b.textContent=n;b.setAttribute('aria-label','Number '+n);b.addEventListener('click',function(){suEnter(n);});np.appendChild(b);})(i);
  }
  var clrb=document.createElement('button');clrb.className='np';clrb.textContent='X';clrb.setAttribute('aria-label','Clear cell');clrb.addEventListener('click',function(){suEnter(0);});np.appendChild(clrb);
  hideMsg('su-msg');suUpdProg();
}
function suPick(el){if(el.classList.contains('given'))return;document.querySelectorAll('.sc').forEach(function(c){c.classList.remove('sel');});el.classList.add('sel');suSel=el;el.focus();}
function suEnter(n){if(!suSel)return;var r=+suSel.dataset.r,c=+suSel.dataset.c;suGrid[r][c]=n;suSel.textContent=n||'';suSel.classList.remove('err');suUpdProg();}
function clearSudoku(){initSudoku();}
function checkSudoku(){
  var ok=0,tot=0;
  document.querySelectorAll('.sc:not(.given)').forEach(function(cell){
    var r=+cell.dataset.r,c=+cell.dataset.c;
    if(suGrid[r][c]!==0){tot++;if(suGrid[r][c]===SU_SOL[r][c]){ok++;cell.classList.remove('err');}else{cell.classList.add('err');}}
  });
  if(tot===0){showMsg('su-msg','no','Select a blank square then tap a number below to start!');return;}
  if(ok===tot)showMsg('su-msg','ok','Great work! All '+ok+' filled cells are correct!');
  else showMsg('su-msg','no',ok+' correct, '+(tot-ok)+' to fix. Wrong cells are shown in red.');
}
function suUpdProg(){
  var f=0;
  for(var r=0;r<9;r++)for(var c=0;c<9;c++)if(SU_PUZ[r][c]===0&&suGrid[r][c]!==0)f++;
  var p=Math.round(f/suBlanks*100);
  document.getElementById('su-pg').style.width=p+'%';
  document.getElementById('su-lbl').textContent='Progress: '+f+' of '+suBlanks+' filled';
}
initSudoku();

// MEMORY MATCH
var MEM_SYMS=['🌸','🦋','🍎','🌙','⭐','🎵','🐦','🌺'];
var mFlipped=[],mMatched=[],mMoves=0,mLock=false,mBest=null;
function initMemory(){
  mFlipped=[];mMatched=[];mMoves=0;mLock=false;
  document.getElementById('mem-moves').textContent='0';
  document.getElementById('mem-pairs').textContent='0';
  hideMsg('mem-msg');
  var deck=MEM_SYMS.concat(MEM_SYMS);deck.sort(function(){return Math.random()-.5;});
  var g=document.getElementById('mgrid');g.innerHTML='';
  deck.forEach(function(sym,i){
    var c=document.createElement('button');c.className='mc fd';c.dataset.val=sym;
    c.innerHTML=sym;c.setAttribute('aria-label','Card '+(i+1)+', face down');
    c.addEventListener('click',function(){mFlip(this);});
    g.appendChild(c);
  });
}
function mFlip(el){
  if(mLock||el.classList.contains('matched')||el.classList.contains('fu'))return;
  el.classList.remove('fd');el.classList.add('fu');
  el.setAttribute('aria-label','Card showing '+el.dataset.val);
  mFlipped.push(el);
  if(mFlipped.length===2){
    mMoves++;document.getElementById('mem-moves').textContent=mMoves;mLock=true;
    if(mFlipped[0].dataset.val===mFlipped[1].dataset.val){
      mFlipped[0].classList.add('matched');mFlipped[1].classList.add('matched');
      mMatched.push(mFlipped[0].dataset.val);
      document.getElementById('mem-pairs').textContent=mMatched.length;
      mFlipped=[];mLock=false;
      if(mMatched.length===MEM_SYMS.length){
        if(mBest===null||mMoves<mBest){mBest=mMoves;document.getElementById('mem-best').textContent=mBest;}
        showMsg('mem-msg','ok','You found all pairs in '+mMoves+' moves!'+(mBest===mMoves?' New best!':''));
      }
    } else {
      var f=mFlipped.slice();
      setTimeout(function(){
        f[0].classList.remove('fu');f[0].classList.add('fd');
        f[1].classList.remove('fu');f[1].classList.add('fd');
        f[0].setAttribute('aria-label','Card face down');f[1].setAttribute('aria-label','Card face down');
        mFlipped=[];mLock=false;
      },1000);
    }
  }
}
initMemory();

// TRIVIA
var TV_QS=[
  {q:"What planet is known as the Red Planet?",o:["Mars","Venus","Jupiter","Saturn"],a:0},
  {q:"Which US state is called the Sunshine State?",o:["California","Hawaii","Florida","Arizona"],a:2},
  {q:"How many sides does a hexagon have?",o:["Five","Six","Seven","Eight"],a:1},
  {q:"What gas do plants absorb to make food?",o:["Oxygen","Nitrogen","Carbon dioxide","Hydrogen"],a:2},
  {q:"Who painted the Mona Lisa?",o:["Michelangelo","Leonardo da Vinci","Rembrandt","Picasso"],a:1},
  {q:"What is the largest organ in the human body?",o:["Heart","Brain","Liver","Skin"],a:3},
  {q:"What year did the first man walk on the moon?",o:["1965","1967","1969","1971"],a:2},
  {q:"Which bird is famous for its colorful fanned tail?",o:["Peacock","Parrot","Flamingo","Toucan"],a:0},
  {q:"How many players from one team are on a basketball court?",o:["4","5","6","7"],a:1},
  {q:"What is the tallest mountain in the world?",o:["K2","Kilimanjaro","Everest","Denali"],a:2},
  {q:"In what country was the Eiffel Tower built?",o:["Italy","Spain","France","Germany"],a:2},
  {q:"What instrument does an orchestra conductor use to lead?",o:["A baton","Drumsticks","A bow","Their voice"],a:0}
];
var tvIdx=0,tvScore=0,tvStreak=0,tvAnswered=false;
function loadTrivia(){
  if(tvIdx>=TV_QS.length){showMsg('tv-msg','ok','You finished all '+TV_QS.length+' questions! Final score: '+tvScore+'/'+TV_QS.length+'. Well done!');document.getElementById('tv-next').style.display='none';return;}
  tvAnswered=false;
  var q=TV_QS[tvIdx];
  document.getElementById('tv-ctr').textContent='Question '+(tvIdx+1)+' of '+TV_QS.length;
  document.getElementById('tv-q').textContent=q.q;
  document.getElementById('tv-pg').style.width=Math.round(tvIdx/TV_QS.length*100)+'%';
  document.getElementById('tv-pglbl').textContent=tvIdx+' of '+TV_QS.length+' answered';
  var opts=document.getElementById('tv-opts');opts.innerHTML='';
  q.o.forEach(function(opt,i){
    var b=document.createElement('button');b.className='opt';b.textContent=opt;
    b.addEventListener('click',function(){tvAnswer(i,b,q.a);});
    opts.appendChild(b);
  });
  hideMsg('tv-msg');document.getElementById('tv-next').style.display='none';
}
function tvAnswer(chosen,btn,correct){
  if(tvAnswered)return;tvAnswered=true;
  document.getElementById('tv-opts').querySelectorAll('.opt').forEach(function(b,i){b.disabled=true;if(i===correct)b.classList.add('correct');});
  if(chosen===correct){tvScore++;tvStreak++;showMsg('tv-msg','ok','Correct! Well done.');}
  else{tvStreak=0;btn.classList.add('wrong');showMsg('tv-msg','no','Not quite -- the answer was: '+TV_QS[tvIdx].o[correct]);}
  document.getElementById('tv-score').textContent=tvScore;
  document.getElementById('tv-streak').textContent=tvStreak;
  document.getElementById('tv-next').style.display='inline-flex';
}
function nextTrivia(){tvIdx++;loadTrivia();}
loadTrivia();

// MATH
var mathDiff='easy',mathScore=0,mathStreak=0,mathBest=0,mathAns=0;
function setDiff(d,el){
  mathDiff=d;
  document.querySelectorAll('.diffbtn').forEach(function(b){b.classList.remove('on');});
  el.classList.add('on');loadMath();
}
function loadMath(){
  hideMsg('math-msg');document.getElementById('math-inp').value='';
  var a,b,op,ans;
  if(mathDiff==='easy'){
    a=Math.floor(Math.random()*10)+1;b=Math.floor(Math.random()*10)+1;
    op=Math.random()>.5?'+':'-';
    if(op==='-'&&b>a){var t=a;a=b;b=t;}
    ans=op==='+'?a+b:a-b;
  } else if(mathDiff==='medium'){
    a=Math.floor(Math.random()*9)+2;b=Math.floor(Math.random()*9)+2;
    if(Math.random()>.5){op='x';ans=a*b;}else{ans=Math.floor(Math.random()*8)+2;a=ans*b;op='->';}
    if(op==='->'){op='/';}
  } else {
    var rn=Math.random();
    if(rn<.5){a=Math.floor(Math.random()*50)+10;b=Math.floor(Math.random()*50)+10;op='+';ans=a+b;}
    else{a=Math.floor(Math.random()*9)+2;b=Math.floor(Math.random()*9)+2;op='x';ans=a*b;}
  }
  mathAns=ans;
  var opDisp=op==='x'?'times':op==='/'?'divided by':op;
  document.getElementById('math-eq').innerHTML=a+' <span class="mathop">'+op+'</span> '+b+' = <span class="mathb">?</span>';
  setTimeout(function(){document.getElementById('math-inp').focus();},80);
}
function checkMath(){
  var v=parseInt(document.getElementById('math-inp').value);
  if(isNaN(v)){showMsg('math-msg','no','Please type a number first.');return;}
  if(v===mathAns){
    mathScore++;mathStreak++;
    if(mathStreak>mathBest){mathBest=mathStreak;document.getElementById('math-best').textContent=mathBest;}
    document.getElementById('math-score').textContent=mathScore;
    document.getElementById('math-streak').textContent=mathStreak;
    showMsg('math-msg','ok','Correct! The answer is '+mathAns+'.');
    setTimeout(loadMath,1300);
  } else {
    mathStreak=0;document.getElementById('math-streak').textContent=0;
    showMsg('math-msg','no','Not quite -- the answer was '+mathAns+'. Try the next one!');
    setTimeout(loadMath,1800);
  }
}
function skipMath(){showMsg('math-msg','no','The answer was '+mathAns+'.');mathStreak=0;document.getElementById('math-streak').textContent=0;setTimeout(loadMath,1300);}
document.getElementById('math-inp').addEventListener('keydown',function(e){if(e.key==='Enter')checkMath();});
loadMath();

// WORD BUILDER
var WB_SETS=[
  {letters:['G','A','R','D','E','N','S'],words:['GARDEN','ANGER','RANGE','GRADE','DEAR','EARN','NEAR','READ','DEAN','DARE','DENS','ENDS','SEND','GEAR','AGES','REND','SANER','READS','GRADS','AND','END','RED','ERA','ARE','EAR','AGE','DEN','RAN','GAN','GAS','SAD','ANS']},
  {letters:['S','P','R','I','N','G','E'],words:['SPRING','SINGER','RINSE','RISEN','SPINE','REINS','SNIPE','PINE','RIPE','GRIN','PINS','SPIN','GRIP','SIREN','GRIPE','PINES','REIGN','PEN','PIN','RIP','GIN','PIG','SIP','SIN','IRE','RIN','PRIG','SNIP','RINS']},
  {letters:['F','L','O','W','E','R','S'],words:['FLOWERS','FOWLER','FLOWER','LOWER','OWLS','LORE','ROLE','ROWS','FLOW','FLEW','SLOW','WOLF','SOLE','LOSE','FOWL','OWL','ROW','LOW','OWE','FOR','ORE','FOE','SOW','FOW','LOWS','OWES','FOES','LORE','WORE','WOES']},
  {letters:['B','R','A','I','N','S','E'],words:['BRAINS','BRINE','BRAIN','RISEN','REINS','RAINS','SIREN','BARE','EARN','NEAR','RAIN','BRAN','SANE','SINE','BEAR','RAISE','BANES','BASER','BAN','BAR','BIN','RAN','RIN','ANE','AIR','RANI','AIRS','BANE','BINS','BARS']}
];
var wbCur='',wbUsed=[],wbFound=[],wbPts=0,wbSet=null,wbLetters=[];
function initWords(){
  wbSet=WB_SETS[Math.floor(Math.random()*WB_SETS.length)];
  wbLetters=wbSet.letters.slice();wbCur='';wbUsed=[];wbFound=[];wbPts=0;
  document.getElementById('wb-words').textContent='0';
  document.getElementById('wb-pts').textContent='0';
  document.getElementById('wbfound').innerHTML='';
  document.getElementById('wbcur').textContent='';
  hideMsg('wb-msg');
  var cont=document.getElementById('wbtiles');cont.innerHTML='';
  wbLetters.forEach(function(l,i){
    var b=document.createElement('button');b.className='wbl';b.textContent=l;b.dataset.idx=i;
    b.setAttribute('aria-label','Letter '+l);
    b.addEventListener('click',function(){wbAdd(+this.dataset.idx,this);});
    cont.appendChild(b);
  });
}
function wbAdd(idx,el){
  if(wbUsed.indexOf(idx)!==-1)return;
  wbUsed.push(idx);wbCur+=wbLetters[idx];
  el.classList.add('used');el.disabled=true;
  document.getElementById('wbcur').textContent=wbCur;
}
function wbDelete(){
  if(!wbCur)return;
  var li=wbUsed.pop();wbCur=wbCur.slice(0,-1);
  document.getElementById('wbcur').textContent=wbCur;
  var tiles=document.getElementById('wbtiles').querySelectorAll('.wbl');
  tiles[li].classList.remove('used');tiles[li].disabled=false;
}
function wbClear(){
  wbCur='';wbUsed=[];
  document.getElementById('wbcur').textContent='';
  document.getElementById('wbtiles').querySelectorAll('.wbl').forEach(function(b){b.classList.remove('used');b.disabled=false;});
}
function wbSubmit(){
  var w=wbCur.toUpperCase();
  if(w.length<3){showMsg('wb-msg','no','Words must be at least 3 letters long.');wbClear();return;}
  if(wbFound.indexOf(w)!==-1){showMsg('wb-msg','no','You already found "'+w+'" -- try another word!');wbClear();return;}
  var valid=wbSet.words.map(function(x){return x.toUpperCase();}).indexOf(w)!==-1;
  if(valid){
    wbFound.push(w);
    var pts=w.length*(w.length>5?2:1);wbPts+=pts;
    document.getElementById('wb-words').textContent=wbFound.length;
    document.getElementById('wb-pts').textContent=wbPts;
    showMsg('wb-msg','ok','"'+w+'" is correct! +'+pts+' points'+(w.length>5?' -- bonus for long word!':'')+'.');
    var tag=document.createElement('span');tag.className='wbword';tag.textContent=w;
    document.getElementById('wbfound').appendChild(tag);
  } else {
    showMsg('wb-msg','no','"'+w+'" is not in the list -- try a different combination!');
  }
  wbClear();
}
initWords();

// WORD SEARCH
var WS_WORDSETS=[
  ['SPRING','BLOOM','GARDEN','RAIN','SUN','BIRD','LEAF'],
  ['WINTER','SNOW','FROST','COLD','ICE','WIND','CLOUD'],
  ['SUMMER','BEACH','SWIM','HEAT','SAND','WAVE','FISH'],
  ['AUTUMN','APPLE','MAPLE','BROWN','GOLD','MIST','WOOD']
];
var wsFoundWords=[],wsPlaced=[],wsGridData=[],wsSize=9,wsFirst=null,wsAllCells=[];
function initWS(){
  wsFoundWords=[];wsFirst=null;hideMsg('ws-msg');
  var wordList=WS_WORDSETS[Math.floor(Math.random()*WS_WORDSETS.length)];
  var result=buildWS(wordList,wsSize);
  wsGridData=result.grid;wsPlaced=result.placed;
  document.getElementById('ws-found').textContent='0';
  document.getElementById('ws-total').textContent=wsPlaced.length;
  renderWSWordList();renderWSGrid();
}
function buildWS(words,n){
  var grid=[];for(var r=0;r<n;r++){grid.push([]);for(var c=0;c<n;c++)grid[r].push('');}
  var placed=[];
  words.forEach(function(word){
    var dirs=[[0,1],[1,0]];
    for(var att=0;att<300;att++){
      var d=dirs[Math.floor(Math.random()*2)];
      var r=Math.floor(Math.random()*n);var c=Math.floor(Math.random()*n);
      var fits=true;
      for(var i=0;i<word.length;i++){
        var nr=r+d[0]*i;var nc=c+d[1]*i;
        if(nr<0||nr>=n||nc<0||nc>=n){fits=false;break;}
        if(grid[nr][nc]!==''&&grid[nr][nc]!==word[i]){fits=false;break;}
      }
      if(fits){
        for(var i=0;i<word.length;i++)grid[r+d[0]*i][c+d[1]*i]=word[i];
        placed.push({word:word,r:r,c:c,dr:d[0],dc:d[1]});break;
      }
    }
  });
  var alpha='ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  for(var r=0;r<n;r++)for(var c=0;c<n;c++)if(grid[r][c]==='')grid[r][c]=alpha[Math.floor(Math.random()*26)];
  return{grid:grid,placed:placed};
}
function renderWSWordList(){
  var cont=document.getElementById('wswordlist');cont.innerHTML='';
  wsPlaced.forEach(function(w){
    var s=document.createElement('span');s.className='wsword';s.textContent=w.word;s.id='wswrd-'+w.word;s.setAttribute('role','listitem');
    cont.appendChild(s);
  });
}
function renderWSGrid(){
  var g=document.getElementById('wsgrid');g.innerHTML='';
  g.style.gridTemplateColumns='repeat('+wsSize+',33px)';
  g.style.gridTemplateRows='repeat('+wsSize+',33px)';
  wsAllCells=[];
  for(var r=0;r<wsSize;r++){
    for(var c=0;c<wsSize;c++){
      var cell=document.createElement('div');cell.className='wscell';cell.textContent=wsGridData[r][c];
      cell.dataset.r=r;cell.dataset.c=c;cell.setAttribute('role','gridcell');
      cell.addEventListener('click',function(){wsClick(this);});
      g.appendChild(cell);wsAllCells.push(cell);
    }
  }
}
function wsClick(el){
  if(el.classList.contains('found'))return;
  if(!wsFirst){wsFirst=el;el.classList.add('sel');showMsg('ws-msg','ok','First letter selected! Now click the last letter of the word.');return;}
  var r1=+wsFirst.dataset.r,c1=+wsFirst.dataset.c;
  var r2=+el.dataset.r,c2=+el.dataset.c;
  wsFirst.classList.remove('sel');wsFirst=null;
  var matched=null;
  wsPlaced.forEach(function(w){
    if(wsFoundWords.indexOf(w.word)!==-1)return;
    var er=w.r+w.dr*(w.word.length-1),ec=w.c+w.dc*(w.word.length-1);
    if((r1===w.r&&c1===w.c&&r2===er&&c2===ec)||(r2===w.r&&c2===w.c&&r1===er&&c1===ec))matched=w;
  });
  if(matched){
    wsFoundWords.push(matched.word);
    for(var i=0;i<matched.word.length;i++){
      var tr=matched.r+matched.dr*i,tc=matched.c+matched.dc*i;
      wsAllCells[tr*wsSize+tc].classList.add('found');
    }
    var wEl=document.getElementById('wswrd-'+matched.word);if(wEl)wEl.classList.add('found');
    document.getElementById('ws-found').textContent=wsFoundWords.length;
    if(wsFoundWords.length===wsPlaced.length)showMsg('ws-msg','ok','You found all the words! Amazing work!');
    else showMsg('ws-msg','ok','Found "'+matched.word+'"! Keep going!');
  } else {
    showMsg('ws-msg','no','That is not a match. Click the FIRST letter of a word, then the LAST letter.');
  }
}
initWS();

// PATTERN MEMORY
var pmSeq=[],pmPlayer=[],pmLevel=1,pmBest=0,pmCanClick=false,pmCells=[];
function initPattern(){
  var g=document.getElementById('pmgrid');g.innerHTML='';pmCells=[];
  for(var i=0;i<9;i++){
    var c=document.createElement('button');c.className='pmcell';c.dataset.i=i;
    c.setAttribute('aria-label','Square '+(i+1));
    c.addEventListener('click',function(){pmPress(+this.dataset.i,this);});
    g.appendChild(c);pmCells.push(c);
  }
}
function pmStart(){
  if(pmSeq.length===0){pmLevel=1;pmSeq=[];document.getElementById('pm-level').textContent=1;}
  pmPlayer=[];pmSeq.push(Math.floor(Math.random()*9));
  document.getElementById('pmphase').textContent='Watch carefully...';
  document.getElementById('pm-level').textContent=pmLevel;
  pmCanClick=false;hideMsg('pm-msg');
  var i=0;
  function next(){
    if(i>=pmSeq.length){pmCanClick=true;document.getElementById('pmphase').textContent='Your turn! Repeat the pattern.';return;}
    var ci=pmSeq[i];
    pmCells[ci].classList.add('lit');
    setTimeout(function(){pmCells[ci].classList.remove('lit');i++;setTimeout(next,320);},580);
  }
  setTimeout(next,500);
}
function pmPress(idx,el){
  if(!pmCanClick)return;
  el.classList.add('pressed');setTimeout(function(){el.classList.remove('pressed');},240);
  pmPlayer.push(idx);
  var pos=pmPlayer.length-1;
  if(pmPlayer[pos]!==pmSeq[pos]){
    pmCanClick=false;
    pmCells[idx].classList.add('wflash');
    setTimeout(function(){pmCells[idx].classList.remove('wflash');},400);
    if(pmLevel>pmBest){pmBest=pmLevel-1;if(pmBest<1)pmBest=1;document.getElementById('pm-best').textContent=pmBest;}
    showMsg('pm-msg','no','Wrong square! You reached level '+pmLevel+'. Press Start to try again!');
    document.getElementById('pmphase').textContent='Game over. Press Start to play again!');
    pmSeq=[];pmLevel=1;document.getElementById('pm-level').textContent=1;
    return;
  }
  if(pmPlayer.length===pmSeq.length){
    pmCanClick=false;
    pmCells.forEach(function(c){c.classList.add('cflash');});
    setTimeout(function(){
      pmCells.forEach(function(c){c.classList.remove('cflash');});
      pmLevel++;
      document.getElementById('pm-level').textContent=pmLevel;
      showMsg('pm-msg','ok','Well done! Level '+pmLevel+' -- press Start for the next round!');
      document.getElementById('pmphase').textContent='Correct! Press Start for the next round.';
    },400);
  }
}
initPattern();

// CROSSWORD
var CW=[['S','U','M','M','E','R','.'],['.','.','.','.','.','.','.'],['.','.','.','.','.','.','.'],['.','.','.','.','.','.','.'],['.','.','S','N','O','W','.'],['.','.','.','.','.','.','.'],['.','.','P','E','T','A','L']];
// Down: SUN col0 rows0-2, FALL col1 rows0-3, RAIN col6 rows0-3, LEAF col3 rows4-6
// Actually build correct layout
var CW7=[
  ['S','U','M','M','E','R','.'],
  ['U','A','.','.','.','.','.'],
  ['N','L','.','.','.','.','.'],
  ['.','L','.','.','.','.','R'],
  ['.','.','S','N','O','W','A'],
  ['.','.','.','.','.','.','I'],
  ['.','.','P','E','T','A','N']
];
var CW_NUMS={'0-0':'1','0-1':'2','0-5':'3','0-6':'4','4-2':'5','6-2':'6','4-5':'7'};
// Simpler crossword -- verified layout
// SUMMER across row 0
// SUN down col 0 rows 0-2
// SNOW across row 4 cols 2-5
// PETAL across row 6 cols 2-6
// FALL down col 1 rows 0-3
// RAIN down col 6 rows 3-6
var CWFINAL=[
  ['S','U','M','M','E','R','.'],
  ['U','A','.','.','.','.','.'],
  ['N','L','.','.','.','.','.'],
  ['.','L','.','.','.','.','R'],
  ['.','.','S','N','O','W','A'],
  ['.','.','.','.','.','.','I'],
  ['.','.','P','E','T','A','N']
];
var CWNUMS={'0-0':'1','0-1':'2','0-5':'3','0-6':'4','4-2':'5','6-2':'6'};
function initCW(){
  var g=document.getElementById('cwgrid');g.innerHTML='';
  for(var r=0;r<7;r++){
    for(var c=0;c<7;c++){
      var cell=document.createElement('div');cell.className='cwc';
      if(CWFINAL[r][c]==='.'){cell.classList.add('black');cell.setAttribute('aria-hidden','true');}
      else{
        var inp=document.createElement('input');inp.maxLength=1;inp.dataset.r=r;inp.dataset.c=c;inp.dataset.ans=CWFINAL[r][c];
        inp.setAttribute('aria-label','Row '+(r+1)+' col '+(c+1));
        inp.addEventListener('input',function(){this.value=this.value.toUpperCase().slice(-1);this.classList.remove('ok','bad');});
        inp.addEventListener('keydown',function(e){
          var nr=+this.dataset.r,nc=+this.dataset.c;
          var navMap={ArrowRight:[nr,nc+1],ArrowLeft:[nr,nc-1],ArrowDown:[nr+1,nc],ArrowUp:[nr-1,nc]};
          if(navMap[e.key]){var n=document.querySelector('input[data-r="'+navMap[e.key][0]+'"][data-c="'+navMap[e.key][1]+'"]');if(n){e.preventDefault();n.focus();}}
        });
        cell.appendChild(inp);
        var k=r+'-'+c;
        if(CWNUMS[k]){var num=document.createElement('span');num.className='cwnum';num.textContent=CWNUMS[k];num.setAttribute('aria-hidden','true');cell.appendChild(num);}
      }
      g.appendChild(cell);
    }
  }
}
function clearCW(){document.querySelectorAll('.cwc input').forEach(function(i){i.value='';i.classList.remove('ok','bad');});hideMsg('cw-msg');}
function checkCW(){
  var ok=0,tot=0;
  document.querySelectorAll('.cwc input').forEach(function(inp){
    if(!inp.value)return;tot++;
    if(inp.value.toUpperCase()===inp.dataset.ans){inp.classList.add('ok');inp.classList.remove('bad');ok++;}
    else{inp.classList.add('bad');inp.classList.remove('ok');}
  });
  if(tot===0){showMsg('cw-msg','no','Click a white square and type a letter to begin!');return;}
  if(ok===tot)showMsg('cw-msg','ok','All your filled letters are correct! Keep going!');
  else showMsg('cw-msg','no',ok+' correct, '+(tot-ok)+' to fix. Wrong letters are shown in red.');
}
initCW();
