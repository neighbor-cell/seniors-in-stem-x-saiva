<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mind Garden — Brain Games for Seniors</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#1C1710;--ink2:#5C4F3A;--ink3:#9C8E78;
  --paper:#FAF7F0;--parchment:#F2EBD9;--linen:#E8DEC8;
  --moss:#4A6741;--mossl:#D4E8C8;--mossd:#2E4228;
  --amber:#C47A2A;--amberl:#F5E8CC;--amberd:#8A5218;
  --rose:#B85C5C;--rosel:#F5DADA;
  --r:16px;--rsm:10px;
  --sh:0 4px 24px rgba(28,23,16,.10);
  --shs:0 2px 8px rgba(28,23,16,.08);
}
*{box-sizing:border-box;margin:0;padding:0;}
html{font-size:18px;scroll-behavior:smooth;}
body{background:var(--paper);color:var(--ink);font-family:'Outfit',sans-serif;line-height:1.6;min-height:100vh;}
.skip{position:absolute;top:-120px;left:0;background:var(--moss);color:#fff;padding:.5rem 1.2rem;font-weight:600;z-index:9999;border-radius:0 0 10px 0;}
.skip:focus{top:0;}
header{background:linear-gradient(135deg,var(--mossd),var(--moss));padding:1.3rem 2rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.8rem;}
.logo{font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#fff;font-weight:600;}
.logo em{color:#B8D8A0;font-style:italic;}
.a11y-bar{display:flex;gap:.5rem;flex-wrap:wrap;}
.a11y-btn{background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.35);border-radius:8px;padding:.35rem .9rem;font-size:.82rem;font-family:'Outfit',sans-serif;color:#fff;cursor:pointer;font-weight:500;transition:all .15s;}
.a11y-btn:hover,.a11y-btn:focus{background:rgba(255,255,255,.28);outline:2px solid #B8D8A0;outline-offset:2px;}
.a11y-btn.on{background:#B8D8A0;color:var(--mossd);border-color:#B8D8A0;}
.hero{background:linear-gradient(135deg,var(--mossd),var(--moss));padding:2.5rem 2rem 4.5rem;text-align:center;position:relative;overflow:hidden;}
.hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:50px;background:var(--paper);clip-path:ellipse(60% 100% at 50% 100%);}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:2.6rem;color:#fff;font-weight:600;margin-bottom:.5rem;position:relative;}
.hero p{color:#C8E0B0;font-size:.95rem;max-width:460px;margin:0 auto;font-weight:300;position:relative;}
main{max-width:900px;margin:0 auto;padding:2rem 1.2rem 5rem;}
.game-nav{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:.8rem;margin-bottom:2rem;}
.gnb{background:var(--paper);border:2px solid var(--linen);border-radius:var(--r);padding:1rem .8rem;cursor:pointer;text-align:center;font-family:'Outfit',sans-serif;transition:all .2s;position:relative;box-shadow:var(--shs);}
.gnb:hover,.gnb:focus{border-color:var(--moss);background:var(--mossl);transform:translateY(-2px);box-shadow:var(--sh);outline:3px solid var(--moss);outline-offset:2px;}
.gnb.active{border-color:var(--mossd);background:var(--mossl);border-width:2.5px;box-shadow:var(--sh);}
.gicon{font-size:1.8rem;margin-bottom:.3rem;display:block;}
.glabel{font-size:.86rem;font-weight:700;color:var(--ink);display:block;}
.gdesc{font-size:.71rem;color:var(--ink3);display:block;margin-top:2px;}
.gbadge{position:absolute;top:-8px;right:-8px;background:var(--amber);color:#fff;font-size:.6rem;font-weight:700;padding:2px 7px;border-radius:20px;}
.panel{display:none;background:var(--paper);border:1.5px solid var(--linen);border-radius:var(--r);padding:1.8rem 1.6rem;box-shadow:var(--sh);animation:sIn .22s ease;}
.panel.active{display:block;}
@keyframes sIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}
.ptitle{font-family:'Cormorant Garamond',serif;font-size:1.85rem;color:var(--ink);margin-bottom:.2rem;font-weight:600;}
.psub{font-size:.83rem;color:var(--ink3);margin-bottom:1.1rem;font-style:italic;}
.instr{background:var(--amberl);border-left:4px solid var(--amber);padding:.85rem 1rem;border-radius:0 var(--rsm) var(--rsm) 0;margin-bottom:1.4rem;font-size:.87rem;color:var(--ink2);line-height:1.6;}
.instr strong{color:var(--ink);}
.btn{display:inline-flex;align-items:center;gap:5px;padding:.62rem 1.25rem;border:2px solid var(--linen);border-radius:var(--rsm);background:var(--parchment);color:var(--ink);font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;transition:all .15s;}
.btn:hover,.btn:focus{background:var(--mossl);border-color:var(--moss);outline:3px solid var(--moss);outline-offset:2px;}
.bgreen{background:var(--moss);color:#fff;border-color:var(--mossd);}
.bgreen:hover,.bgreen:focus{background:var(--mossd);}
.bamber{background:var(--amber);color:#fff;border-color:var(--amberd);}
.bamber:hover,.bamber:focus{background:var(--amberd);}
.brow{display:flex;gap:.7rem;flex-wrap:wrap;justify-content:center;margin-top:1.1rem;}
.msg{padding:.9rem 1.1rem;border-radius:var(--rsm);font-size:.9rem;font-weight:600;margin-top:1rem;text-align:center;display:none;animation:pop .2s ease;}
@keyframes pop{from{transform:scale(.96)}to{transform:scale(1)}}
.msg.ok{background:var(--mossl);color:var(--mossd);border:2px solid var(--moss);}
.msg.no{background:var(--rosel);color:var(--rose);border:2px solid var(--rose);}
.msg.show{display:block;}
.stats{display:flex;gap:.7rem;margin-bottom:1.3rem;flex-wrap:wrap;}
.stat{flex:1;min-width:70px;background:var(--parchment);border-radius:var(--rsm);padding:.72rem;text-align:center;border:1px solid var(--linen);}
.snum{font-size:1.55rem;font-weight:700;color:var(--mossd);font-family:'Cormorant Garamond',serif;}
.slbl{font-size:.7rem;color:var(--ink3);margin-top:2px;font-weight:500;}
.pgwrap{margin-top:1rem;}
.pglbl{font-size:.77rem;color:var(--ink3);margin-bottom:4px;font-weight:500;}
.pgbar{height:8px;background:var(--linen);border-radius:4px;overflow:hidden;}
.pgfill{height:100%;background:linear-gradient(90deg,var(--moss),var(--mossd));border-radius:4px;transition:width .4s;}
/* SUDOKU */
.sugrid{display:grid;grid-template-columns:repeat(9,1fr);background:var(--ink);gap:1px;border:3px solid var(--ink);max-width:378px;margin:0 auto 1rem;overflow-x:auto;}
.sc{background:#fff;aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:var(--ink);cursor:pointer;border:none;width:100%;font-family:'Outfit',sans-serif;}
.sc.given{color:var(--mossd);background:var(--mossl);}
.sc.sel{background:#FFFBEB;outline:3px solid var(--amber);outline-offset:-2px;}
.sc.err{background:var(--rosel);color:var(--rose);}
.sc.br{border-right:2.5px solid var(--ink);}
.sc.bb{border-bottom:2.5px solid var(--ink);}
.numpad{display:flex;gap:7px;flex-wrap:wrap;justify-content:center;margin:.85rem 0;}
.np{width:45px;height:45px;border:2px solid var(--linen);border-radius:8px;background:var(--parchment);font-size:1.1rem;font-weight:700;cursor:pointer;color:var(--ink);font-family:'Outfit',sans-serif;transition:all .15s;}
.np:hover,.np:focus{background:var(--mossl);border-color:var(--moss);outline:2px solid var(--moss);outline-offset:2px;}
/* MEMORY */
.mgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;max-width:440px;margin:0 auto 1.2rem;}
.mc{aspect-ratio:1;border-radius:12px;border:2px solid var(--linen);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:2rem;background:var(--mossd);transition:transform .18s,background .18s;user-select:none;box-shadow:var(--shs);}
.mc:hover{transform:scale(1.04);}
.mc:focus{outline:4px solid var(--amber);outline-offset:2px;}
.mc.fd{font-size:0;background:linear-gradient(135deg,var(--mossd),var(--moss));}
.mc.fd::after{content:'🌿';font-size:1.3rem;}
.mc.fu{background:#fff;}
.mc.matched{background:var(--mossl);border-color:var(--moss);pointer-events:none;transform:none;}
/* TRIVIA */
.qtext{font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:600;color:var(--ink);margin-bottom:1.1rem;line-height:1.45;}
.qopts{display:grid;grid-template-columns:1fr 1fr;gap:.65rem;margin-bottom:1rem;}
@media(max-width:480px){.qopts{grid-template-columns:1fr;}}
.opt{background:var(--parchment);border:2px solid var(--linen);border-radius:var(--rsm);padding:.8rem 1rem;text-align:left;font-size:.88rem;font-family:'Outfit',sans-serif;color:var(--ink);cursor:pointer;transition:all .18s;font-weight:500;line-height:1.4;}
.opt:hover,.opt:focus{background:var(--mossl);border-color:var(--moss);outline:2px solid var(--moss);outline-offset:2px;}
.opt.correct{background:var(--mossl);border-color:var(--mossd);color:var(--mossd);}
.opt.wrong{background:var(--rosel);border-color:var(--rose);color:var(--rose);}
.opt:disabled{cursor:default;}
.qctr{font-size:.78rem;color:var(--ink3);margin-bottom:.5rem;font-weight:600;letter-spacing:.5px;text-transform:uppercase;}
/* MATH */
.matheq{font-family:'Cormorant Garamond',serif;font-size:2.6rem;font-weight:600;text-align:center;padding:1.3rem;background:var(--parchment);border-radius:var(--r);margin-bottom:1rem;color:var(--ink);border:2px solid var(--linen);}
.mathop{color:var(--amberd);}
.mathb{color:var(--moss);}
.mathinp{width:130px;font-size:1.5rem;text-align:center;padding:.6rem;border:2px solid var(--linen);border-radius:var(--rsm);background:#fff;color:var(--ink);font-family:'Cormorant Garamond',serif;display:block;margin:0 auto .5rem;}
.mathinp:focus{outline:3px solid var(--moss);border-color:var(--moss);}
.diffrow{display:flex;gap:.5rem;justify-content:center;margin-bottom:1.2rem;}
.diffbtn{padding:.48rem 1.1rem;border:2px solid var(--linen);border-radius:20px;background:var(--parchment);font-size:.83rem;font-weight:600;cursor:pointer;font-family:'Outfit',sans-serif;color:var(--ink);transition:all .15s;}
.diffbtn.on{background:var(--moss);color:#fff;border-color:var(--mossd);}
/* WORD BUILDER */
.wbtiles{display:flex;gap:9px;flex-wrap:wrap;justify-content:center;margin:1rem 0;}
.wbl{width:50px;height:50px;background:linear-gradient(135deg,var(--moss),var(--mossd));color:#fff;border:2px solid var(--mossd);border-radius:10px;font-size:1.3rem;font-weight:700;cursor:pointer;font-family:'Cormorant Garamond',serif;display:flex;align-items:center;justify-content:center;transition:all .15s;box-shadow:0 3px 8px rgba(46,66,40,.22);}
.wbl:hover,.wbl:focus{transform:translateY(-2px);box-shadow:0 5px 12px rgba(46,66,40,.32);outline:2px solid var(--amber);outline-offset:2px;}
.wbl.used{background:var(--linen);color:var(--ink3);border-color:var(--linen);cursor:default;box-shadow:none;transform:none;}
.wbcur{font-size:1.9rem;font-weight:700;letter-spacing:9px;text-align:center;min-height:3rem;padding:.55rem;background:var(--parchment);border-radius:var(--r);border:2px solid var(--linen);margin-bottom:.75rem;font-family:'Cormorant Garamond',serif;color:var(--ink);}
.wbfound{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:1rem;min-height:2rem;}
.wbword{background:var(--mossl);color:var(--mossd);border:1.5px solid var(--moss);border-radius:20px;padding:3px 11px;font-size:.81rem;font-weight:600;animation:pop .2s ease;}
/* WORD SEARCH */
.wsgrid{display:inline-grid;gap:2px;background:var(--linen);border:2px solid var(--linen);border-radius:var(--rsm);overflow:hidden;}
.wscell{width:33px;height:33px;background:#fff;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;cursor:pointer;color:var(--ink);user-select:none;transition:background .12s;font-family:'Outfit',sans-serif;}
.wscell:hover{background:var(--amberl);}
.wscell.sel{background:var(--amberl);color:var(--amberd);}
.wscell.found{background:var(--mossl);color:var(--mossd);}
.wswordlist{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;}
.wsword{padding:4px 13px;border:2px solid var(--linen);border-radius:20px;font-size:.83rem;font-weight:600;color:var(--ink2);background:var(--parchment);}
.wsword.found{background:var(--mossl);color:var(--mossd);border-color:var(--moss);text-decoration:line-through;}
/* PATTERN MEMORY */
.pmgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;max-width:270px;margin:0 auto 1.2rem;}
.pmcell{aspect-ratio:1;border-radius:12px;border:2px solid var(--linen);cursor:pointer;background:var(--parchment);transition:all .15s;box-shadow:var(--shs);}
.pmcell:hover,.pmcell:focus{border-color:var(--moss);outline:2px solid var(--moss);outline-offset:2px;}
.pmcell.lit{background:var(--amber);border-color:var(--amberd);box-shadow:0 0 18px rgba(196,122,42,.5);}
.pmcell.pressed{background:#5B9BD5;border-color:#2E6DA4;box-shadow:0 0 14px rgba(91,155,213,.4);}
.pmcell.cflash{background:var(--moss);border-color:var(--mossd);}
.pmcell.wflash{background:var(--rose);border-color:var(--rose);}
.pmphase{font-size:.98rem;font-weight:600;text-align:center;padding:.65rem 1rem;background:var(--parchment);border:1px solid var(--linen);border-radius:var(--rsm);margin-bottom:1rem;color:var(--ink2);}
/* CROSSWORD */
.cwgrid{display:inline-grid;gap:2px;background:var(--ink);border:3px solid var(--ink);}
.cwc{width:36px;height:36px;background:#fff;position:relative;}
.cwc.black{background:var(--ink);}
.cwc input{width:100%;height:100%;border:none;background:transparent;text-align:center;font-size:.98rem;font-weight:700;text-transform:uppercase;color:var(--ink);font-family:'Outfit',sans-serif;outline:none;padding:0;cursor:pointer;}
.cwc input:focus{background:#FFFBEB;}
.cwc input.ok{color:var(--mossd);}
.cwc input.bad{color:var(--rose);background:var(--rosel);}
.cwnum{position:absolute;top:1px;left:2px;font-size:7.5px;color:var(--ink3);line-height:1;pointer-events:none;font-weight:700;}
.clues{display:grid;grid-template-columns:1fr 1fr;gap:1.4rem;margin-top:1.1rem;}
@media(max-width:500px){.clues{grid-template-columns:1fr;}}
.cgrp h3{font-size:.78rem;font-weight:700;color:var(--ink3);margin-bottom:.55rem;text-transform:uppercase;letter-spacing:1.5px;}
.ci{font-size:.87rem;color:var(--ink);margin-bottom:.42rem;line-height:1.4;}
.ci span{color:var(--ink3);font-weight:700;}
footer{background:var(--parchment);border-top:1px solid var(--linen);text-align:center;padding:2rem 1rem;color:var(--ink3);font-size:.79rem;}
footer strong{color:var(--ink2);}
/* LARGE TEXT */
body.large{font-size:22px;}
body.large .sc{font-size:1.2rem;}
body.large .np{width:54px;height:54px;font-size:1.3rem;}
body.large .opt{font-size:1rem;padding:1rem;}
body.large .matheq{font-size:3rem;}
body.large .wscell{width:38px;height:38px;}
/* HIGH CONTRAST */
body.hc{--paper:#0a0a0a;--parchment:#1a1a1a;--linen:#333;--ink:#fff;--ink2:#ddd;--ink3:#aaa;--moss:#4CD964;--mossl:#0a2a10;--mossd:#4CD964;--amber:#FFB347;--amberl:#2a1800;--amberd:#FFB347;--rose:#FF6B6B;--rosel:#2a0808;}
body.hc header,body.hc .hero{background:#111;}
body.hc .mc.fd{background:#333;}
body.hc .sugrid,.body.hc .cwgrid{background:#fff;}
@media(max-width:520px){
  html{font-size:16px;}
  .hero h1{font-size:1.9rem;}
  .panel{padding:1.2rem 1rem;}
  .matheq{font-size:2rem;}
  .wbcur{font-size:1.4rem;letter-spacing:6px;}
}
</style>
</head>
<body>
<a href="#main" class="skip">Skip to games</a>
<header role="banner">
  <div class="logo">🌿 Mind <em>Garden</em></div>
  <nav class="a11y-bar" aria-label="Accessibility">
    <button class="a11y-btn" id="btn-large" onclick="toggleLarge()" aria-pressed="false">Larger text</button>
    <button class="a11y-btn" id="btn-hc" onclick="toggleHC()" aria-pressed="false">High contrast</button>
  </nav>
</header>
<div class="hero">
  <h1>Brain Games for Seniors</h1>
  <p>Eight free activities to keep your mind sharp. No sign-up, no cost, play anytime on any device.</p>
</div>
<main id="main">
  <nav class="game-nav" aria-label="Choose a game">
    <button class="gnb active" onclick="showGame('sudoku',this)"><span class="gicon">🔢</span><span class="glabel">Sudoku</span><span class="gdesc">Fill the grid</span></button>
    <button class="gnb" onclick="showGame('memory',this)"><span class="gicon">🃏</span><span class="glabel">Memory Match</span><span class="gdesc">Find the pairs</span></button>
    <button class="gnb" onclick="showGame('trivia',this)"><span class="gicon">💡</span><span class="glabel">Trivia</span><span class="gdesc">Test your knowledge</span></button>
    <button class="gnb" onclick="showGame('math',this)"><span class="gicon">🧮</span><span class="glabel">Math</span><span class="gdesc">Quick calculations</span></button>
    <button class="gnb" onclick="showGame('words',this)"><span class="gicon">🔤</span><span class="glabel">Word Builder</span><span class="gdesc">Make words</span><span class="gbadge">NEW</span></button>
    <button class="gnb" onclick="showGame('wordsearch',this)"><span class="gicon">🔍</span><span class="glabel">Word Search</span><span class="gdesc">Find hidden words</span><span class="gbadge">NEW</span></button>
    <button class="gnb" onclick="showGame('pattern',this)"><span class="gicon">🟡</span><span class="glabel">Pattern Memory</span><span class="gdesc">Repeat the sequence</span><span class="gbadge">NEW</span></button>
    <button class="gnb" onclick="showGame('crossword',this)"><span class="gicon">📝</span><span class="glabel">Crossword</span><span class="gdesc">Solve the clues</span></button>
  </nav>

  <!-- SUDOKU -->
  <section id="panel-sudoku" class="panel active" aria-label="Sudoku">
    <h2 class="ptitle">Sudoku</h2>
    <p class="psub">A classic logic puzzle — great for warming up your brain</p>
    <div class="instr"><strong>How to play:</strong> Click any blank square, then tap a number below to fill it in. Every row, column, and 3x3 box must use each number 1-9 exactly once. Green squares are given clues you cannot change.</div>
    <div style="overflow-x:auto"><div class="sugrid" id="sugrid" role="grid"></div></div>
    <div class="numpad" id="numpad" role="group" aria-label="Number pad"></div>
    <div class="brow">
      <button class="btn" onclick="clearSudoku()">Clear all</button>
      <button class="btn bgreen" onclick="checkSudoku()">Check answers</button>
    </div>
    <div id="su-msg" class="msg" role="alert" aria-live="polite"></div>
    <div class="pgwrap"><div class="pglbl" id="su-lbl">Progress: 0 of 51 filled</div><div class="pgbar"><div class="pgfill" id="su-pg" style="width:0%"></div></div></div>
  </section>

  <!-- MEMORY -->
  <section id="panel-memory" class="panel" aria-label="Memory Match">
    <h2 class="ptitle">Memory Match</h2>
    <p class="psub">Flip cards and find all 8 matching pairs</p>
    <div class="instr"><strong>How to play:</strong> Click any card to flip it over and reveal the picture. Then click another card. If the two pictures match, they stay face-up! If not, they flip back over. Find all 8 pairs to win.</div>
    <div class="stats" role="status" aria-live="polite">
      <div class="stat"><div class="snum" id="mem-moves">0</div><div class="slbl">Moves</div></div>
      <div class="stat"><div class="snum" id="mem-pairs">0</div><div class="slbl">Pairs found</div></div>
      <div class="stat"><div class="snum" id="mem-best">--</div><div class="slbl">Best score</div></div>
    </div>
    <div class="mgrid" id="mgrid" role="grid"></div>
    <div class="brow"><button class="btn bgreen" onclick="initMemory()">New game</button></div>
    <div id="mem-msg" class="msg" role="alert" aria-live="polite"></div>
  </section>

  <!-- TRIVIA -->
  <section id="panel-trivia" class="panel" aria-label="Trivia">
    <h2 class="ptitle">Trivia Challenge</h2>
    <p class="psub">History, nature, science, and everyday life</p>
    <div class="instr"><strong>How to play:</strong> Read each question and click the answer you think is correct. You will find out straight away whether you are right. Build up your streak to show off your knowledge!</div>
    <div class="stats" role="status" aria-live="polite">
      <div class="stat"><div class="snum" id="tv-score">0</div><div class="slbl">Score</div></div>
      <div class="stat"><div class="snum" id="tv-streak">0</div><div class="slbl">Streak</div></div>
    </div>
    <div class="qctr" id="tv-ctr">Question 1 of 12</div>
    <div class="qtext" id="tv-q" aria-live="polite">Loading...</div>
    <div class="qopts" id="tv-opts" role="group" aria-label="Answer choices"></div>
    <div id="tv-msg" class="msg" role="alert" aria-live="polite"></div>
    <div class="brow"><button class="btn bgreen" id="tv-next" onclick="nextTrivia()" style="display:none">Next question</button></div>
    <div class="pgwrap"><div class="pglbl" id="tv-pglbl">0 of 12 answered</div><div class="pgbar"><div class="pgfill" id="tv-pg" style="width:0%"></div></div></div>
  </section>

  <!-- MATH -->
  <section id="panel-math" class="panel" aria-label="Math Puzzles">
    <h2 class="ptitle">Math Puzzles</h2>
