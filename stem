<script>
// ACCESSIBILITY
function toggleLarge(){var on=document.body.classList.toggle('large');var b=document.getElementById('btn-large');b.setAttribute('aria-pressed',on);b.classList.toggle('on',on);}
function toggleHC(){var on=document.body.classList.toggle('hc');var b=document.getElementById('btn-hc');b.setAttribute('aria-pressed',on);b.classList.toggle('on',on);}

// NAV
function showGame(id,el){
  document.querySelectorAll('.gnb').forEach(function(b){b.classList.remove('active');});
  document.querySelectorAll('.panel').forEach(function(p){p.classList.remove('active');});
